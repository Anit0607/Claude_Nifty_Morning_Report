# Copy this file to `.env` and fill in values. NEVER commit `.env`.

# Dhan API — refreshed daily during testing phase
DHAN_ACCESS_TOKEN=
DHAN_CLIENT_ID=

# Email delivery (Gmail) — primary channel. EMAIL_APP_PASSWORD is a Google App Password
# (needs 2FA on the account), NOT your normal password. EMAIL_TO can be comma-separated.
EMAIL_USER=
EMAIL_APP_PASSWORD=
EMAIL_TO=

# Telegram delivery (optional / banned in IN) — leave blank to disable
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OPTIONAL — only needed for the richer LLM narration/diagnosis layer.
# The system runs fully without this (deterministic report).
ANTHROPIC_API_KEY=
